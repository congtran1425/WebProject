{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "^/$", "dest": "/api/index.php" },
    { "src": "^/admin/(.*)$", "dest": "/api/admin/$1" },
    { "src": "^/([^?]+\\.php)$", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": ".*", "dest": "/api/index.php" }
  ]
}
